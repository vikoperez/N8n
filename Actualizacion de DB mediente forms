      "parameters": {
        "operation": "executeQuery",
        "query": "-- ===============================\n--  DECLARACIÓN DE VARIABLES\n-- ===============================\nDECLARE \n  @NumeroDocumento BIGINT,\n  @TipoDocumentoID INT,\n  @Nombre NVARCHAR(50),\n  @Apellidos NVARCHAR(50),\n  @FechaNacimiento DATETIME,\n  @SexoTexto NVARCHAR(10),\n  @RH NVARCHAR(3),\n  @Direccion NVARCHAR(100),\n  @Ciudad NVARCHAR(50),\n  @NumeroTelefono NVARCHAR(20),\n  @Email NVARCHAR(100),\n  @CargoID INT,\n  @EmpresaID INT,\n  @EPS NVARCHAR(50),\n  @AFP NVARCHAR(50),\n  @IDSupervisor INT,\n  @CreatedTime DATETIME,\n  @ErrorMsg NVARCHAR(500),\n  @RowNumber INT;\n\n-- ===============================\n--  ASIGNACIÓN DE VALORES\n-- ===============================\nBEGIN TRY\n  SET @RowNumber = {{ $json._row_number }};\n  SET @NumeroDocumento = TRY_CAST('{{ $json.cedula_limpia }}' AS BIGINT);\n  \n  -- Validar que la cédula se convirtió correctamente\n  IF @NumeroDocumento IS NULL OR @NumeroDocumento = 0\n    THROW 50001, 'Cédula no válida o es cero', 1;\n  \n  -- Obtener IDs de tablas relacionadas con manejo de errores detallado\n  SET @TipoDocumentoID = (\n    SELECT TOP 1 ID \n    FROM TipoDocumento \n    WHERE UPPER(LTRIM(RTRIM(Descripcion))) = UPPER(LTRIM(RTRIM('{{ $json[\"Tipo documento\"] }}')))\n  );\n  \n  SET @CargoID = (\n    SELECT TOP 1 ID \n    FROM Cargo \n    WHERE UPPER(LTRIM(RTRIM(Descripcion))) = UPPER(LTRIM(RTRIM('{{ $json.Cargo }}')))\n  );\n  \n  SET @EmpresaID = (\n    SELECT TOP 1 ID \n    FROM Empresa \n    WHERE UPPER(LTRIM(RTRIM(Nombre))) = UPPER(LTRIM(RTRIM('{{ $json[\"Empresa a la que perteneces\"] }}')))\n  );\n  \n  -- Validar que existen los registros relacionados\n  IF @TipoDocumentoID IS NULL\n    THROW 50002, 'Tipo de documento no encontrado en la base de datos: {{ $json[\"Tipo documento\"] }}', 1;\n  IF @CargoID IS NULL\n    THROW 50003, 'Cargo no encontrado en la base de datos: {{ $json.Cargo }}', 1;\n  IF @EmpresaID IS NULL\n    THROW 50004, 'Empresa no encontrada en la base de datos: {{ $json[\"Empresa a la que perteneces\"] }}', 1;\n  \n  SET @Nombre = UPPER(LTRIM(RTRIM('{{ $json.Nombre }}')));\n  SET @Apellidos = UPPER(LTRIM(RTRIM('{{ $json.Apellidos }}')));\n  SET @FechaNacimiento = TRY_CONVERT(DATETIME, '{{ $json.fecha_nacimiento_limpia }}', 111);\n  \n  -- Validar fecha de nacimiento\n  IF @FechaNacimiento IS NULL\n    THROW 50005, 'Fecha de nacimiento inválida: {{ $json.fecha_nacimiento_limpia }}', 1;\n  \n  IF @FechaNacimiento > GETDATE()\n    THROW 50006, 'Fecha de nacimiento no puede ser futura', 1;\n    \n  IF @FechaNacimiento < '1900-01-01'\n    THROW 50007, 'Fecha de nacimiento demasiado antigua', 1;\n  \n  SET @SexoTexto = UPPER('{{ $json.Sexo }}');\n  SET @RH = UPPER(LTRIM(RTRIM('{{ $json[\"Tipo de Sangre\"] }}')));\n  SET @Direccion = UPPER(LTRIM(RTRIM('{{ $json[\"Dirección de residencia (Especificar la ciudad)\"] }}')));\n  SET @Ciudad = LTRIM(RTRIM('{{ $json.Sede }}'));\n  SET @NumeroTelefono = '{{ $json.telefono_limpio }}';\n  SET @Email = UPPER(LTRIM(RTRIM('{{ $json[\"E-mail personal\"] }}')));\n  SET @EPS = UPPER(LTRIM(RTRIM('{{ $json.EPS }}')));\n  SET @AFP = NULL;\n  SET @CreatedTime = GETDATE();\n  \n  -- Buscar supervisor (permitir NULL si no se encuentra)\n  SET @IDSupervisor = NULL;\n  \n  IF LEN(LTRIM(RTRIM('{{ $json[\"Nombre del Jefe Inmediato\"] }}'))) > 0\n  BEGIN\n    SET @IDSupervisor = (\n      SELECT TOP 1 e.ID\n      FROM dbo.Empleado AS e\n      WHERE \n        e.EstadoEmpleado = 1\n        AND (\n          (LTRIM(RTRIM(e.Nombre)) + ' ' + LTRIM(RTRIM(e.Apellidos))) LIKE '%' + LTRIM(RTRIM('{{ $json[\"Nombre del Jefe Inmediato\"] }}')) + '%'\n          OR (LTRIM(RTRIM(e.Apellidos)) + ' ' + LTRIM(RTRIM(e.Nombre))) LIKE '%' + LTRIM(RTRIM('{{ $json[\"Nombre del Jefe Inmediato\"] }}')) + '%'\n        )\n    );\n  END;\n\n  -- ===============================\n  --  UPSERT (insert/update)\n  -- ===============================\n  IF EXISTS (SELECT 1 FROM dbo.Empleado WHERE NumeroDocumento = @NumeroDocumento)\n  BEGIN\n    UPDATE Empleado\n    SET\n      TipoDocumento = @TipoDocumentoID,\n      Nombre = @Nombre,\n      Apellidos = @Apellidos,\n      FechaNacimiento = @FechaNacimiento,\n      Sexo = LEFT(@SexoTexto, 1),\n      RH = @RH,\n      Direccion = @Direccion,\n      Ciudad = @Ciudad,\n      NumeroTelefono = @NumeroTelefono,\n      Email = @Email,\n      CargoID = @CargoID,\n      EmpresaID = @EmpresaID,\n      EPS = @EPS,\n      AFP = @AFP,\n      IDSupervisor = @IDSupervisor,\n      FechaIngreso = ISNULL(FechaIngreso, @CreatedTime)\n    WHERE NumeroDocumento = @NumeroDocumento;\n    \n    SELECT \n      'ok' AS status, \n      @NumeroDocumento AS documento, \n      'updated' AS action,\n      @Nombre + ' ' + @Apellidos AS nombre_completo,\n      @RowNumber AS row_number,\n      @@ROWCOUNT AS rows_affected;\n  END\n  ELSE\n  BEGIN\n    INSERT INTO Empleado\n    (NumeroDocumento, TipoDocumento, Nombre, Apellidos, FechaNacimiento, Sexo, RH, Direccion, \n     Ciudad, NumeroTelefono, Email, CargoID, EmpresaID, EPS, AFP, IDSupervisor, FechaIngreso, EstadoEmpleado)\n    VALUES\n    (\n      @NumeroDocumento, @TipoDocumentoID, @Nombre, @Apellidos, @FechaNacimiento,\n      LEFT(@SexoTexto, 1), @RH, @Direccion, @Ciudad, @NumeroTelefono, @Email,\n      @CargoID, @EmpresaID, @EPS, @AFP, @IDSupervisor, @CreatedTime, 1\n    );\n    \n    SELECT \n      'ok' AS status, \n      @NumeroDocumento AS documento, \n      'inserted' AS action,\n      @Nombre + ' ' + @Apellidos AS nombre_completo,\n      @RowNumber AS row_number,\n      @@ROWCOUNT AS rows_affected;\n  END;\n\nEND TRY\nBEGIN CATCH\n  SELECT \n    'error' AS status,\n    @NumeroDocumento AS documento,\n    ERROR_MESSAGE() AS error_message,\n    ERROR_NUMBER() AS error_number,\n    ERROR_LINE() AS error_line,\n    @RowNumber AS row_number;\nEND CATCH;"
      },
