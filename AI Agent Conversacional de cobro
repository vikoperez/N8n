      "parameters": {
        "operation": "executeQuery",
        "query": "DECLARE @cedula NVARCHAR(50) = '{{ $json.cedula }}';\n\nIF EXISTS (\n    SELECT 1 \n    FROM EstadoClienteSumasAdmin\n    WHERE [Nit / Cedula] = @cedula\n)\nBEGIN\n    SELECT\n        [nombre_cliente],\n        [Marca],\n        [dias_de_mora],\n        [Vlr_Saldo total]\n    FROM EstadoClienteSumasAdmin\n    WHERE [Nit / Cedula] = @cedula;\nEND\nELSE\nBEGIN\n    SELECT\n        'No existe' AS [nombre_cliente],\n        'No existe' AS [Marca],\n        'No existe' AS [dias_de_mora],\n        'No existe' AS [Vlr_Saldo total];\nEND"
