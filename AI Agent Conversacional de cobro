      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// Paso 1 — Extraer el texto de la respuesta del clasificador\nlet text = '';\n\nif (raw.output && Array.isArray(raw.output)) {\n  text = raw.output?.[0]?.content?.[0]?.text || '';\n} else if (typeof raw.output === 'string') {\n  text = raw.output;\n} else if (raw.message?.content) {\n  text = raw.message.content;\n}\n\n// Paso 2 — Limpiar markdown accidental\nconst clean = text.replace(/```json|```/g, '').trim();\n\n// Paso 3 — Parsear el JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(clean);\n} catch (e) {\n  parsed = {\n    hablar_con_persona:   false,\n    envio_cedula:         false,\n    cedulas_encontradas:  [],\n    cedula_indicada:      null,\n    cedula:               null,\n    consultar_bd:         false,\n    multiples_cedulas:    false,\n    cliente_molesto:      false,\n    menciona_pago:        false,\n    niega_deuda:          false,\n    mensaje_normal:       true,\n    solicita_medios_pago: false\n  };\n}\n\n// Paso 4 — Construir resultado con todos los campos garantizados\nconst resultado = {\n  hablar_con_persona:   parsed.hablar_con_persona   ?? false,\n  envio_cedula:         parsed.envio_cedula         ?? false,\n  cedulas_encontradas:  parsed.cedulas_encontradas  ?? [],\n  cedula_indicada:      parsed.cedula_indicada      ?? null,\n  cedula:               parsed.cedula               ?? null,\n  consultar_bd:         parsed.consultar_bd         ?? false,\n  multiples_cedulas:    parsed.multiples_cedulas    ?? false,\n  cliente_molesto:      parsed.cliente_molesto      ?? false,\n  menciona_pago:        parsed.menciona_pago        ?? false,\n  niega_deuda:          parsed.niega_deuda          ?? false,\n  mensaje_normal:       parsed.mensaje_normal       ?? false,\n  solicita_medios_pago: parsed.solicita_medios_pago ?? false\n};\n\n// Paso 5 — Suprimir consulta BD solo si el cliente NO envió cédula nueva en este turno\n// FIX: antes suprimía siempre que cliente_conocido=true, lo que impedía actualizar\n// la cédula si el cliente enviaba una corrección en un turno posterior.\ntry {\n  const contextoRedis = $('PARSE - Resolver Contexto Cliente').first().json;\n  const clienteConocido = contextoRedis.cliente_conocido;\n  const envioNuevaCedula = resultado.envio_cedula === true;\n\n  if (clienteConocido && !envioNuevaCedula) {\n    // Cliente ya conocido y no mandó cédula nueva → no re-consultar BD\n    resultado.consultar_bd    = false;\n    resultado.cedula_presente = true;\n  }\n  // Si envioNuevaCedula=true, se respeta el consultar_bd que devolvió el clasificador\n} catch(e) {\n  // Si el nodo no existe o falla, continuamos sin modificar\n}\n\nreturn [{ json: resultado }];"
      },
