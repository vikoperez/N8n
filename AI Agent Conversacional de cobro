ente == null;\n\n    // FIX: antes usaba solo clas.cedula, que es null cuando el cliente\n    // no envió cédula en este turno pero ya tenía una guardada en Redis.\n    // Ahora: preferir la cédula nueva del clasificador, con fallback a Redis.\n    const cedulaResuelta = clas.cedula ?? redis.cedula ?? null;\n\n    if (noExiste) {\n      return [{ json: {\n        ...base,\n        cedula_presente:      true,\n        cedula:               cedulaResuelta,   // ← FIX\n        cliente_existe_bd:    false,\n        tiene_obligaciones:   false,\n        obligaciones:         [],\n        cantidad_obligaciones: 0,\n        ruta_tomada:          'Consultar_BD'\n      }}];\n    }\n\n    return [{ json: {\n      ...base,\n      cedula_presente:       true,\n      cedula:                cedulaResuelta,     // ← FIX\n      nombre_cliente:        primer.nombre_cliente || '',\n      cliente_existe_bd:     true,\n      tiene_obligaciones:    true,\n      obligaciones:          bdItems.map(i => ({\n                               marca:        i.json.Marca              || '',\n                               dias_de_mora: i.json.dias_de_mora       || 0,\n                               saldo:        i.json['Vlr_Saldo total'] || 0\n                             })),\n      cantidad_obligaciones: bdItems.length,\n      ruta_tomada:           'Consultar_BD'\n    }}];\n  }\n} catch(e) {\n  // BD no corrió en esta ejecución → seguimos evaluando rutas\n}\n\n// Ruta 4: Múltiples cédulas\nif (clas.multiples_cedulas === true) {\n  return [{ json: {\n    ...base,\n    cedula:               null,\n    cedula_presente:      false,\n    multiples_cedulas:    true,\n    cedulas_encontradas:  JSON.stringify(clas.cedulas_encontradas ?? []),\n    ruta_tomada:          'Múltiples_Cédulas'\n  }}];\n}\n\n// Ruta 5: Sin cédula (fallback)\nreturn [{ json: {\n  ...base,\n  ruta_tomada: 'Sin_Cédula'\n}}];"
