        "jsCode": "const raw = $input.first().json;\nconst pre = $input.first().json;;\n\nconst outputStr = raw.output || '{}';\n\nlet respuesta;\ntry {\n  const limpio = outputStr\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .replace(/^[^{]*({[\\s\\S]*})[^}]*$/, '$1')  // extrae solo el JSON aunque haya texto antes/después\n    .trim();\n  respuesta = JSON.parse(limpio);\n} catch(e) {\n  respuesta = {\n    tipo_documento: 'OTRO',\n    urgencia: 'MEDIA',\n    nivel_urgencia_numerico: 3,\n    entidad_tipo: 'DESCONOCIDO',\n    hechos_clave: ['Error al parsear respuesta IA - revisión manual requerida'],\n    terminos_legales_detectados: 'No determinado',\n    termino_vencido_detectado: false,\n    area_responsable: 'Legal',\n    respuesta_sugerida: 'En proceso de clasificación manual.',\n    resumen_ejecutivo: 'Correo recibido - clasificación automática falló'\n  };\n}\n\n// Validar que nivel_urgencia_numerico sea 1-4\nconst nivel = parseInt(respuesta.nivel_urgencia_numerico);\nconst nivelValido = (nivel >= 1 && nivel <= 4) ? nivel : 3;\n\nreturn [{\n  json: {\n    radicado_id:              pre.radicado_id              || '',\n    message_id:               pre.message_id               || '',\n    fecha_recepcion:          pre.fecha_recepcion          || '',\n    asunto:                   pre.asunto                   || '',\n    remitente_nombre:         pre.remitente_nombre         || '',\n    remitente_email:          pre.remitente_email          || '',\n    tiene_adjuntos:           pre.tiene_adjuntos           || false,\n    cantidad_adjuntos:        pre.cantidad_adjuntos        || 0,\n    adjuntos_detalle:         pre.adjuntos_detalle         || '[]',\n    cuenta_origen:            pre.cuenta_origen            || '',\n    numero_whatsapp_destino:  pre.numero_whatsapp_destino  || '573159976203@s.whatsapp.net',\n\n    ...respuesta,\n\n    nivel_urgencia_numerico: nivelValido,\n\n    hechos_clave_texto: Array.isArray(respuesta.hechos_clave)\n      ? respuesta.hechos_clave.join('\\n• ')\n      : String(respuesta.hechos_clave || '')\n  }\n}];"
