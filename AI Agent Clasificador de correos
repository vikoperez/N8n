        "jsCode": "// ============================================================\n// NODO 2: PREPROCESAMIENTO DE CORREO (con enrutamiento WA)\n// ============================================================\n\nconst raw = $input.first().json;\n\n// ── NUEVO: detectar origen y asignar número WhatsApp ────────\nconst origenNodo = $prevNode.name;\n\nconst NUMERO_WHATSAPP = (origenNodo === 'Email Trigger (IMAP)2')\n  ? '573054314251@s.whatsapp.net'\n  : '573159976203@s.whatsapp.net'; // IMAP e IMAP1 → mismo número\n\n// ── Limpieza HTML ───────────────────────────────────────────\nfunction stripHtml(html) {\n  if (!html) return '';\n  return html\n    .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<br\\s*\\/?>/gi, '\\n')\n    .replace(/<\\/p>/gi, '\\n\\n')\n    .replace(/<[^>]+>/g, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\")\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n}\n\n// ── Radicado único ──────────────────────────────────────────\nfunction generarRadicado() {\n  const now = new Date();\n  const año = now.getFullYear();\n  const mes = String(now.getMonth() + 1).padStart(2, '0');\n  const dia = String(now.getDate()).padStart(2, '0');\n  const hora = String(now.getHours()).padStart(2, '0');\n  const min = String(now.getMinutes()).padStart(2, '0');\n  const seg = String(now.getSeconds()).padStart(2, '0');\n  const rand = Math.floor(Math.random() * 9000) + 1000;\n  return `RAD-${año}${mes}${dia}-${hora}${min}${seg}-${rand}`;\n}\n\n// ── Parsear remitente ───────────────────────────────────────\nfunction parsearRemitente(fromStr) {\n  if (!fromStr) return { nombre: 'Desconocido', email: 'sin-email@desconocido.com' };\n  const match = fromStr.match(/^(.*?)\\s*<([^>]+)>/);\n  if (match) {\n    return {\n      nombre: match[1].replace(/\"/g, '').trim() || 'Sin nombre',\n      email: match[2].trim().toLowerCase()\n    };\n  }\n  const emailMatch = fromStr.match(/[\\w.-]+@[\\w.-]+\\.\\w+/);\n  return {\n    nombre: fromStr.trim(),\n    email: emailMatch ? emailMatch[0] : fromStr.trim()\n  };\n}\n\n// ── Adjuntos ────────────────────────────────────────────────\nconst adjuntos = raw.attachments || [];\nconst tieneAdjuntos = adjuntos.length > 0;\nconst tiposAdjuntos = adjuntos.map(a => ({\n  nombre: a.filename || 'sin-nombre',\n  tipo: a.contentType || 'application/octet-stream',\n  tamaño: a.size || 0\n}));\n\n// ── Cuerpo ──────────────────────────────────────────────────\nconst cuerpoHtml = raw.html || '';\nconst cuerpoTexto = raw.text || stripHtml(cuerpoHtml);\nconst cuerpoLimpio = cuerpoTexto.substring(0, 8000);\n\nconst remitente = parsearRemitente(raw.from);\n\n// ── Output ──────────────────────────────────────────────────\nreturn [{\n  json: {\n    radicado_id:            generarRadicado(),\n    message_id:             raw.messageId || '',\n    fecha_recepcion:        raw.date || new Date().toISOString(),\n    asunto:                 raw.subject || '(Sin asunto)',\n    remitente_nombre:       remitente.nombre,\n    remitente_email:        remitente.email,\n    cuerpo_limpio:          cuerpoLimpio,\n    cuerpo_html_original:   cuerpoHtml.substring(0, 50000),\n    tiene_adjuntos:         tieneAdjuntos,\n    cantidad_adjuntos:      adjuntos.length,\n    adjuntos_detalle:       JSON.stringify(tiposAdjuntos),\n\n    // ── NUEVO ──────────────────────────────────────────────\n    cuenta_origen:          origenNodo,\n    numero_whatsapp_destino: NUMERO_WHATSAPP,\n\n    input_para_ia: `ASUNTO: ${raw.subject || '(Sin asunto)'}\nREMITENTE: ${raw.from || 'Desconocido'}\nFECHA: ${raw.date || new Date().toISOString()}\nTIENE ADJUNTOS: ${tieneAdjuntos ? 'SÍ - ' + tiposAdjuntos.map(a => a.nombre).join(', ') : 'NO'}\n\nCUERPO DEL CORREO:\n${cuerpoLimpio}`\n  }\n}];"
